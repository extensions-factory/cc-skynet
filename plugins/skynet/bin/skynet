#!/usr/bin/env bash
set -euo pipefail

# Resolve symlinks to find actual script location
SCRIPT_SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT_SOURCE" ]; do
  SCRIPT_SOURCE="$(readlink "$SCRIPT_SOURCE")"
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_SOURCE")" && pwd)"
PLUGIN_DIR="$(dirname "$SCRIPT_DIR")"

# shellcheck source=../lib/common.sh
source "$PLUGIN_DIR/lib/common.sh"

PREREQUISITES_FILE="$PLUGIN_DIR/prerequisites.json"

usage() {
  printf "%bskynet%b — AI orchestrator CLI\n" "$BOLD" "$RESET"
  printf "\n"
  printf "%bUsage:%b\n" "$BOLD" "$RESET"
  printf "  skynet <command>\n"
  printf "\n"
  printf "%bCommands:%b\n" "$BOLD" "$RESET"
  printf "  doctor    Check prerequisites and system readiness\n"
  printf "  version   Show version\n"
  printf "  help      Show this help message\n"
}

# ── doctor ──────────────────────────────────────────────
cmd_doctor() {
  printf "\n${BOLD}[SKYNET] Doctor — checking prerequisites${RESET}\n\n"

  if [ ! -f "$PREREQUISITES_FILE" ]; then
    fail "prerequisites.json not found at $PREREQUISITES_FILE"
    exit 1
  fi

  local platform
  platform="$(detect_platform)"

  local total=0
  local passed=0
  local failed=0
  local missing_required=()

  while IFS='|' read -r name command required description install_cmd; do
    total=$((total + 1))

    if eval "$command" > /dev/null 2>&1; then
      local ver
      ver=$(eval "$command" 2>&1 | head -1)
      ok "$name — $ver"
      passed=$((passed + 1))
    else
      if [ "$required" = "true" ]; then
        fail "$name — not found (required)"
        if [ -n "$install_cmd" ]; then
          printf "    ${YELLOW}→ Install: ${RESET}%s\n" "$install_cmd"
        fi
        failed=$((failed + 1))
        missing_required+=("$name")
      else
        warn "$name — not found (optional)"
        if [ -n "$install_cmd" ]; then
          printf "    ${YELLOW}→ Install: ${RESET}%s\n" "$install_cmd"
        fi
      fi
    fi
  done < <(python3 -c "
import json, sys

with open('$PREREQUISITES_FILE') as f:
    data = json.load(f)

platform = '$platform'
for p in data['prerequisites']:
    install_cmd = p.get('install', {}).get(platform, '')
    print(f\"{p['name']}|{p['command']}|{p.get('required', False)}|{p['description']}|{install_cmd}\")
")

  # Summary
  printf "\n${BOLD}Summary:${RESET} %s/%s passed" "$passed" "$total"
  if [ "$failed" -gt 0 ]; then
    printf ", ${RED}%s failed${RESET}" "$failed"
  fi
  printf "\n"

  if [ ${#missing_required[@]} -gt 0 ]; then
    printf "\n${RED}${BOLD}Action required:${RESET} Install missing dependencies before using Skynet.\n"
    return 1
  else
    printf "\n${GREEN}${BOLD}All good!${RESET} System is ready.\n"
    return 0
  fi
}

# ── version ─────────────────────────────────────────────
cmd_version() {
  printf "skynet %s\n" "$(plugin_version)"
}

# ── Main ────────────────────────────────────────────────
case "${1:-help}" in
  doctor)  cmd_doctor ;;
  version) cmd_version ;;
  help|--help|-h) usage ;;
  *)
    fail "Unknown command: $1"
    usage
    exit 1
    ;;
esac
