#!/usr/bin/env bash
set -euo pipefail

# Resolve symlinks to find actual script location
SCRIPT_SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT_SOURCE" ]; do
  SCRIPT_SOURCE="$(readlink "$SCRIPT_SOURCE")"
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_SOURCE")" && pwd)"
PLUGIN_DIR="$(dirname "$SCRIPT_DIR")"

# shellcheck source=../lib/common.sh
source "$PLUGIN_DIR/lib/common.sh"
# shellcheck source=../lib/sources.sh
source "$PLUGIN_DIR/lib/sources.sh"
# shellcheck source=../lib/workers.sh
source "$PLUGIN_DIR/lib/workers.sh"

PREREQUISITES_FILE="$PLUGIN_DIR/prerequisites.json"

usage() {
  printf "%bskynet%b — AI orchestrator CLI\n" "$BOLD" "$RESET"
  printf "\n"
  printf "%bUsage:%b\n" "$BOLD" "$RESET"
  printf "  skynet <command>\n"
  printf "\n"
  printf "%bCommands:%b\n" "$BOLD" "$RESET"
  printf "  doctor    Check prerequisites and system readiness\n"
  printf "  init      Initialize worker system (~/.claude/skynet/)\n"
  printf "  source    Manage external skill/agent repositories\n"
  printf "  import    Import skills/agents into current project\n"
  printf "  unimport  Remove imported skills/agents\n"
  printf "  version   Show version\n"
  printf "  help      Show this help message\n"
}

# ── doctor ──────────────────────────────────────────────
cmd_doctor() {
  printf "\n${BOLD}[SKYNET] Doctor — checking prerequisites${RESET}\n\n"

  if [ ! -f "$PREREQUISITES_FILE" ]; then
    fail "prerequisites.json not found at $PREREQUISITES_FILE"
    exit 1
  fi

  local platform
  platform="$(detect_platform)"

  local total=0
  local passed=0
  local failed=0
  local missing_required=()

  while IFS='|' read -r name command required description install_cmd; do
    total=$((total + 1))

    local -a cmd_arr
    read -ra cmd_arr <<< "$command"

    if "${cmd_arr[@]}" > /dev/null 2>&1; then
      local ver
      ver=$("${cmd_arr[@]}" 2>&1 | head -1)
      ok "$name — $ver"
      passed=$((passed + 1))
    else
      if [ "$required" = "true" ]; then
        fail "$name — not found (required)"
        if [ -n "$install_cmd" ]; then
          printf "    ${YELLOW}→ Install: ${RESET}%s\n" "$install_cmd"
        fi
        failed=$((failed + 1))
        missing_required+=("$name")
      else
        warn "$name — not found (optional)"
        if [ -n "$install_cmd" ]; then
          printf "    ${YELLOW}→ Install: ${RESET}%s\n" "$install_cmd"
        fi
      fi
    fi
  done < <(_PREREQUISITES_FILE="$PREREQUISITES_FILE" _PLATFORM="$platform" python3 -c "
import json, os, sys

with open(os.environ['_PREREQUISITES_FILE']) as f:
    data = json.load(f)

platform = os.environ['_PLATFORM']
for p in data['prerequisites']:
    install_cmd = p.get('install', {}).get(platform, '')
    print(f\"{p['name']}|{p['command']}|{p.get('required', False)}|{p['description']}|{install_cmd}\")
")

  # Summary
  printf "\n${BOLD}Summary:${RESET} %s/%s passed" "$passed" "$total"
  if [ "$failed" -gt 0 ]; then
    printf ", ${RED}%s failed${RESET}" "$failed"
  fi
  printf "\n"

  if [ ${#missing_required[@]} -gt 0 ]; then
    printf "\n${RED}${BOLD}Action required:${RESET} Install missing dependencies before using Skynet.\n"
    return 1
  else
    printf "\n${GREEN}${BOLD}All good!${RESET} System is ready.\n"
    return 0
  fi
}

# ── version ─────────────────────────────────────────────
cmd_version() {
  printf "skynet %s\n" "$(plugin_version)"
}

# ── source ─────────────────────────────────────────────
cmd_source() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    add)
      local repo_url="${1:-}" name=""
      [ -z "$repo_url" ] && { fail "Usage: skynet source add <repo-url> [--name <alias>]"; return 1; }
      shift
      while [ $# -gt 0 ]; do
        case "$1" in
          --name) name="$2"; shift 2 ;;
          *) shift ;;
        esac
      done
      source_add "$repo_url" "$name"
      ;;
    sync)
      local target="${1:---all}" auto="false"
      [ "$target" = "--auto" ] && { auto="true"; target="--all"; }
      [ "${2:-}" = "--auto" ] && auto="true"
      source_sync "$target" "$auto"
      ;;
    list)
      source_list
      ;;
    remove)
      local name="${1:-}"
      [ -z "$name" ] && { fail "Usage: skynet source remove <name>"; return 1; }
      source_remove "$name"
      ;;
    *)
      printf "${BOLD}skynet source${RESET} — manage external repositories\n\n"
      printf "  add <url> [--name <alias>]   Register a source\n"
      printf "  sync [--all|<name>]          Clone or pull updates\n"
      printf "  list                         Show registered sources\n"
      printf "  remove <name>                Unregister a source\n"
      ;;
  esac
}

# ── import ─────────────────────────────────────────────
cmd_import() {
  local arg="${1:-}"

  case "$arg" in
    --list)
      import_list "${2:-}"
      ;;
    --search)
      [ -z "${2:-}" ] && { fail "Usage: skynet import --search <query>"; return 1; }
      import_search "$2"
      ;;
    --sync)
      import_sync
      ;;
    --index)
      import_build_index
      ;;
    --targets)
      [ -z "${2:-}" ] && { fail "Usage: skynet import --targets claude,gemini,codex"; return 1; }
      import_set_targets "$2"
      ;;
    --help|"")
      printf "${BOLD}skynet import${RESET} — import skills/agents into current project\n\n"
      printf "  <source>:<name> [--as <n>] [--type skill|agent]   Import an item\n"
      printf "  --list [<source>]                                  Browse available items\n"
      printf "  --search <query>                                   Search across sources\n"
      printf "  --index                                            Build compact skill index\n"
      printf "  --sync                                             Re-create symlinks from manifest\n"
      printf "  --targets claude,gemini,codex                      Set target tools\n"
      ;;
    *)
      # Parse <source>:<name>
      local source name as_name="" type="skill"
      if [[ "$arg" == *":"* ]]; then
        source="${arg%%:*}"
        name="${arg#*:}"
      else
        fail "Usage: skynet import <source>:<name>"
        return 1
      fi

      shift
      while [ $# -gt 0 ]; do
        case "$1" in
          --as) as_name="$2"; shift 2 ;;
          --type) type="$2"; shift 2 ;;
          *) shift ;;
        esac
      done

      [ -z "$as_name" ] && as_name="$name"
      import_link "$source" "$type" "$name" "$as_name"
      ;;
  esac
}

# ── unimport ───────────────────────────────────────────
cmd_unimport() {
  local name="${1:-}"
  [ -z "$name" ] && { fail "Usage: skynet unimport <name>"; return 1; }
  import_unlink "$name"
}

# ── init ──────────────────────────────────────────────────
cmd_init() {
  local reset="false"
  [ "${1:-}" = "--reset" ] && reset="true"

  printf "\n${BOLD}[SKYNET] Initializing worker system${RESET}\n\n"

  if [ "$reset" = "true" ]; then
    if [ -f "$SKYNET_CONFIG" ]; then
      info "Resetting config to defaults..."
      rm -f "$SKYNET_CONFIG"
    fi
  fi

  # Create directory structure
  ensure_skynet_home
  ok "Directory: $SKYNET_HOME"

  # Create config
  if ensure_config; then
    ok "Created: config.json (defaults)"
  else
    info "Config: config.json (already exists)"
  fi

  # Create workers registry
  if ensure_workers_registry; then
    ok "Created: workers.json (empty registry)"
  else
    info "Registry: workers.json (already exists)"
  fi

  printf "\n${GREEN}${BOLD}Worker system initialized.${RESET}\n"
  printf "  Config:      %s\n" "$SKYNET_CONFIG"
  printf "  Workers:     %s\n" "$SKYNET_WORKERS"
  printf "  Credentials: %s\n" "$SKYNET_CREDENTIALS"
  printf "\nNext: add a worker with ${BOLD}genisys add <name> --provider <claude|gemini|codex>${RESET}\n"
}

# ── Main ────────────────────────────────────────────────
case "${1:-help}" in
  init)     shift; cmd_init "$@" ;;
  doctor)   cmd_doctor ;;
  source)   shift; cmd_source "$@" ;;
  import)   shift; cmd_import "$@" ;;
  unimport) shift; cmd_unimport "$@" ;;
  version)  cmd_version ;;
  help|--help|-h) usage ;;
  *)
    fail "Unknown command: $1"
    usage
    exit 1
    ;;
esac
