{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PLUGIN_DIR=$(awk '/skynet@cc-skynet/,/installPath/' \"$HOME/.claude/plugins/installed_plugins.json\" | grep installPath | sed 's/.*\"installPath\": *\"\\([^\"]*\\)\".*/\\1/') && awk '/@hook:SessionStart/,/@end:SessionStart/' \"$PLUGIN_DIR/rules/session/greet.md\""
          }
        ]
      }
    ],
    "InstructionsLoaded": [],
    "SessionEnd": [],

    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PLUGIN_DIR=$(awk '/skynet@cc-skynet/,/installPath/' \"$HOME/.claude/plugins/installed_plugins.json\" | grep installPath | sed 's/.*\"installPath\": *\"\\([^\"]*\\)\".*/\\1/') && awk '/@hook:UserPromptSubmit/,/@end:UserPromptSubmit/' \"$PLUGIN_DIR/rules/versioning/auto-bump-before-commit.md\""
          }
        ]
      }
    ],
    "Elicitation": [],
    "ElicitationResult": [],

    "PreToolUse": [],
    "PostToolUse": [],
    "PostToolUseFailure": [],
    "PermissionRequest": [],

    "SubagentStart": [],
    "SubagentStop": [],
    "TeammateIdle": [],
    "TaskCompleted": [],

    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PLUGIN_DIR=$(awk '/skynet@cc-skynet/,/installPath/' \"$HOME/.claude/plugins/installed_plugins.json\" | grep installPath | sed 's/.*\"installPath\": *\"\\([^\"]*\\)\".*/\\1/') && awk '/@hook:Stop/,/@end:Stop/' \"$PLUGIN_DIR/rules/versioning/suffix-bump.md\""
          }
        ]
      }
    ],
    "StopFailure": [],

    "WorktreeCreate": [],
    "WorktreeRemove": [],

    "ConfigChange": [],

    "PreCompact": [],
    "PostCompact": [],

    "Notification": []
  }
}
