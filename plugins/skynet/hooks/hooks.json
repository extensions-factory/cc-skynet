{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude plugin update skynet@cc-skynet 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "latest=$(ls -1 \"$HOME/.claude/plugins/cache/cc-skynet/skynet\" 2>/dev/null | sort -V | tail -1); script=\"$HOME/.claude/plugins/cache/cc-skynet/skynet/$latest/scripts/setup/setup-cron.sh\"; [ -n \"$latest\" ] && [ -f \"$script\" ] && bash \"$script\" || true"
          },
          {
            "type": "command",
            "command": "latest=$(ls -1 \"$HOME/.claude/plugins/cache/cc-skynet/skynet\" 2>/dev/null | sort -V | tail -1); script=\"$HOME/.claude/plugins/cache/cc-skynet/skynet/$latest/scripts/setup/auto-update.sh\"; [ -n \"$latest\" ] && [ -f \"$script\" ] && bash \"$script\" || true"
          },
          {
            "type": "command",
            "command": "latest=$(ls -1 \"$HOME/.claude/plugins/cache/cc-skynet/skynet\" 2>/dev/null | sort -V | tail -1); script=\"$HOME/.claude/plugins/cache/cc-skynet/skynet/$latest/scripts/setup/skills-link.sh\"; [ -n \"$latest\" ] && [ -f \"$script\" ] && bash \"$script\" || true"
          },
          {
            "type": "command",
            "command": "latest=$(ls -1 \"$HOME/.claude/plugins/cache/cc-skynet/skynet\" 2>/dev/null | sort -V | tail -1); script=\"$HOME/.claude/plugins/cache/cc-skynet/skynet/$latest/scripts/setup/agents-link.sh\"; [ -n \"$latest\" ] && [ -f \"$script\" ] && bash \"$script\" || true"
          },
          {
            "type": "command",
            "command": "awk '/@hook:SessionStart:greeting/,/@end:SessionStart:greeting/' .claude/rules/orchestrator.md 2>/dev/null | grep -v '@hook:\\|@end:' || true"
          },
          {
            "type": "command",
            "command": "latest=$(ls -1 \"$HOME/.claude/plugins/cache/cc-skynet/skynet\" 2>/dev/null | sort -V | tail -1); profile=\"$HOME/.claude/plugins/cache/cc-skynet/skynet/$latest/pool-profiles/pool-1-claude-1-codex-3-gemini.md\"; [ -n \"$latest\" ] && [ -f \"$profile\" ] && printf '\\n---\\n' && cat \"$profile\" || true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); PROMPT=$(echo \"$INPUT\" | jq -r '.prompt // empty' | tr 'A-Z' 'a-z'); case \"$PROMPT\" in *commit*) awk '/@hook:UserPromptSubmit/,/@end:UserPromptSubmit/' .claude/rules/commit.md 2>/dev/null | grep -v '@hook:\\|@end:';; esac; true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "awk '/@hook:PreToolUse:Edit\\|Write/,/@end:PreToolUse:Edit\\|Write/' .claude/rules/delegation.md 2>/dev/null | grep -v '@hook:\\|@end:' || true"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); CMD=$(echo \"$INPUT\" | jq -r '.tool_input.command // empty'); case \"$CMD\" in *spawn-*-worker*|*create-task*|*skills-link*|*skills-fetch*|*agents-link*|*setup-cron*|*auto-update*|*log-common*) ;; *\"tasks/.output\"*|*\"tasks/.pipe\"*|*SCRIPT_DIR*|*\"plugins/cache/cc-skynet\"*) ;; *) awk '/@hook:PreToolUse:Bash/,/@end:PreToolUse:Bash/' .claude/rules/delegation.md 2>/dev/null | grep -v '@hook:\\|@end:' ;; esac; true"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "awk '/@hook:PreToolUse:Agent/,/@end:PreToolUse:Agent/' .claude/rules/delegation.md 2>/dev/null | grep -v '@hook:\\|@end:'; awk '/@hook:PreToolUse:Agent/,/@end:PreToolUse:Agent/' .claude/rules/skill-triggers.md 2>/dev/null | grep -v '@hook:\\|@end:'; true"
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); FILE=$(echo \"$INPUT\" | jq -r '.tool_input.file_path // empty'); CMD=$(echo \"$INPUT\" | jq -r '.tool_input.command // empty'); CHECK=\"$FILE $CMD\"; case \"$CHECK\" in *\"/.env\"*|*\"/.env.\"*|*\".credentials\"*|*\"docker-compose.prod.yml\"*) awk '/@hook:PreToolUse:protected-files/,/@end:PreToolUse:protected-files/' .claude/rules/orchestrator.md 2>/dev/null | grep -v '@hook:\\|@end:' >&2; exit 2;; esac"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "awk '/@hook:SubagentStop/,/@end:SubagentStop/' .claude/rules/delegation.md 2>/dev/null | grep -v '@hook:\\|@end:'; awk '/@hook:SubagentStop/,/@end:SubagentStop/' .claude/rules/build-counter.md 2>/dev/null | grep -v '@hook:\\|@end:'; true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "awk '/@hook:Stop/,/@end:Stop/' .claude/rules/orchestrator.md 2>/dev/null | grep -v '@hook:\\|@end:' || true"
          }
        ]
      }
    ]
  }
}
