{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude plugin update skynet@cc-skynet 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "script=$(ls \"$HOME/.claude/plugins/cache/cc-skynet/skynet/\"*/scripts/setup-cron.sh 2>/dev/null | tail -1) && [ -n \"$script\" ] && bash \"$script\" || true"
          },
          {
            "type": "command",
            "command": "script=$(ls \"$HOME/.claude/plugins/cache/cc-skynet/skynet/\"*/scripts/auto-update.sh 2>/dev/null | sort | tail -1) && [ -n \"$script\" ] && bash \"$script\" || true"
          },
          {
            "type": "command",
            "command": "script=$(ls \"$HOME/.claude/plugins/cache/cc-skynet/skynet/\"*/scripts/skills-link.sh 2>/dev/null | sort | tail -1) && [ -n \"$script\" ] && bash \"$script\" || true"
          },
          {
            "type": "command",
            "command": "script=$(ls \"$HOME/.claude/plugins/cache/cc-skynet/skynet/\"*/scripts/agents-link.sh 2>/dev/null | sort | tail -1) && [ -n \"$script\" ] && bash \"$script\" || true"
          },
          {
            "type": "command",
            "command": "if [ -d .claude/rules ]; then for f in .claude/rules/*.md; do [ -f \"$f\" ] && printf '\\n---\\n' && cat \"$f\"; done; fi"
          },
          {
            "type": "command",
            "command": "printf 'Greet the user as Skynet — the AI orchestrator at first response. One line only: [SKYNET] Online và Sẵn sàng phục vụ'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); FILE=$(echo \"$INPUT\" | jq -r '.tool_input.file_path // empty'); CMD=$(echo \"$INPUT\" | jq -r '.tool_input.command // empty'); CHECK=\"$FILE $CMD\"; case \"$CHECK\" in *\".env\"*|*\".env.local\"*|*\".env.production\"*|*\".credentials\"*|*\"docker-compose.prod.yml\"*) echo \"BLOCKED: protected file detected in '$FILE$CMD'. Edit it manually.\" >&2; exit 2;; esac"
          }
        ]
      }
    ]
  }
}
